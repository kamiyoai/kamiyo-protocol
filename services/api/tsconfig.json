{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "src/hive-agent.ts",
    "src/api/routes/arena.ts",
    "src/api/routes/sap.ts",
    "src/arena-sap.ts",
    "src/arena-solana.ts",
    "src/arena.ts",
    "src/sap-registration.ts",
    "src/sap-x402-runtime.ts",
    "src/sap-x402.ts",
    "src/sap.ts",
    "src/x402-runtime.ts"
  ]
}
