{
  "name": "kamiyo-companion",
  "version": "1.0.0",
  "description": "KAMIYO Companion API for Kizuna credits, billing, and retained integration surfaces",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/mcp/idl && cp src/mcp/idl/x402_escrow.json dist/mcp/idl/",
    "start": "COMPANION_RUNTIME_PROFILE=kizuna-core COMPANION_ROUTE_SURFACE=kizuna-core node dist/index.js",
    "start:core": "COMPANION_RUNTIME_PROFILE=kizuna-core COMPANION_ROUTE_SURFACE=kizuna-core node dist/index.js",
    "start:full": "COMPANION_RUNTIME_PROFILE=full COMPANION_ROUTE_SURFACE=full node dist/index.js",
    "start:full-core-surface": "COMPANION_RUNTIME_PROFILE=full COMPANION_ROUTE_SURFACE=kizuna-core node dist/index.js",
    "dev": "COMPANION_RUNTIME_PROFILE=kizuna-core COMPANION_ROUTE_SURFACE=kizuna-core tsx watch src/index.ts",
    "dev:core": "COMPANION_RUNTIME_PROFILE=kizuna-core COMPANION_ROUTE_SURFACE=kizuna-core tsx watch src/index.ts",
    "dev:full": "COMPANION_RUNTIME_PROFILE=full COMPANION_ROUTE_SURFACE=full tsx watch src/index.ts",
    "dev:full-core-surface": "COMPANION_RUNTIME_PROFILE=full COMPANION_ROUTE_SURFACE=kizuna-core tsx watch src/index.ts",
    "company:heartbeat": "tsx scripts/run-company-heartbeat.ts",
    "babyagi:dev": "tsx src/babyagi-bridge-server.ts",
    "provision:oobe-mcp-client": "tsx scripts/provision-oobe-mcp-client.ts",
    "register:sap-agent-mainnet": "tsx scripts/register-sap-agent-mainnet.ts",
    "preflight:contract": "node scripts/preflight-env.mjs --mode contract",
    "preflight:env": "node scripts/preflight-env.mjs --mode runtime",
    "smoke:health": "node scripts/smoke-health.mjs",
    "smoke:route-ownership": "node scripts/smoke-route-ownership.mjs",
    "pretest": "node scripts/ensure-better-sqlite3.mjs",
    "test": "vitest run --no-file-parallelism src/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@origintrail-official/dkg-agent": "0.0.1-dev.1774254893.acaccb6",
    "@coral-xyz/anchor": "^0.31.1",
    "@kamiyo/agent-paranet": "workspace:*",
    "@kamiyo/agents": "workspace:*",
    "@kamiyo/daydreams": "workspace:*",
    "@kamiyo/hive": "workspace:*",
    "@kamiyo/reality-fork-dkg": "workspace:*",
    "@kamiyo/meishi": "workspace:*",
    "@kamiyo-org/selfimprove": "workspace:*",
    "@kamiyo/x402-client": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.25.0",
    "@oobe-protocol-labs/synapse-sap-sdk": "0.4.1",
    "@sentry/node": "^10.40.0",
    "@solana/web3.js": "^1.98.0",
    "@types/multer": "^2.1.0",
    "better-sqlite3": "^11.0.0",
    "bs58": "^6.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openai": "^6.25.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "prom-client": "^15.1.0",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.29.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/bs58": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
