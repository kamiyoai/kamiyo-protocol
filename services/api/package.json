{
  "name": "kamiyo-companion",
  "version": "1.0.0",
  "description": "KAMIYO Companion - AI interface to KAMIYO protocol (API + X bot)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/mcp/idl && cp src/mcp/idl/x402_escrow.json dist/mcp/idl/",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "babyagi:dev": "tsx src/babyagi-bridge-server.ts",
    "preflight:contract": "node scripts/preflight-env.mjs --mode contract",
    "preflight:env": "node scripts/preflight-env.mjs --mode runtime",
    "smoke:health": "node scripts/smoke-health.mjs",
    "pretest": "node scripts/ensure-better-sqlite3.mjs",
    "test": "vitest run src/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@coral-xyz/anchor": "^0.31.1",
    "@modelcontextprotocol/sdk": "^1.25.0",
    "@kamiyo/agent-paranet": "workspace:*",
    "@kamiyo/agents": "workspace:*",
    "@kamiyo/hive": "workspace:*",
    "@kamiyo/daydreams": "workspace:*",
    "@kamiyo/meishi": "workspace:*",
    "@kamiyo/swarm-agents": "workspace:*",
    "@kamiyo/x402-client": "workspace:*",
    "@sentry/node": "^10.40.0",
    "@solana/web3.js": "^1.98.0",
    "better-sqlite3": "^11.0.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.25.0",
    "prom-client": "^15.1.0",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.18.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/bs58": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/ws": "^8.5.12",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
