{
  "name": "@kamiyo/protocol-tick",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Protocol maintenance and research tick — produces real on-chain tx for kizuna dashboard",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
