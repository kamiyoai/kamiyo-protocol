# Observatory (Helius-backed escrow/dispute ingestion)

PORT=8787
MAX_BODY_BYTES=5000000

# Where the SQLite database is stored. Use ":memory:" for ephemeral runs/tests.
OBS_DB_PATH=data/observatory/observatory.db

# Verify `x-helius-signature` on incoming webhooks.
HELIUS_WEBHOOK_SECRET=

# Required for `POST /backfill/transactions` (Bearer auth).
OBS_ADMIN_SECRET=

# Optional: if set, backfill uses Helius enhanced transactions.
HELIUS_API_KEY=

# Optional: used for RPC backfill when `HELIUS_API_KEY` is not set.
SOLANA_RPC_URL=
OBS_CLUSTER=mainnet-beta

# Used to parse only your escrow program instructions from webhook tx payloads.
# `ESCROW_PROGRAM_ID` is the repo-wide default; `OBS_PROGRAM_ID` overrides it for this service.
ESCROW_PROGRAM_ID=
OBS_PROGRAM_ID=
