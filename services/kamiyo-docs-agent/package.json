{
  "name": "@kamiyo/docs-agent",
  "version": "0.1.0",
  "description": "Regenerates README and CHANGELOG on merge to main via the shared Kamiyo agent runtime with DB-backed self-improve",
  "main": "dist/index.js",
  "bin": {
    "kamiyo-docs-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "pnpm build && node --test dist/tools.test.js dist/agent.test.js dist/reconcile.test.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "reconcile": "tsx src/reconcile.ts"
  },
  "dependencies": {
    "@kamiyo-org/agent": "file:../../packages/kamiyo-agent",
    "@kamiyo-org/selfimprove": "file:../../packages/kamiyo-selfimprove",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
