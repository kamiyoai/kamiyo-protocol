# Kyoshin accelerated 24h autonomy qualification profile.
# This is an overlay file: apply these values on top of your base runtime .env.

KAMIYO_MODE=execute
KAMIYO_LLM_ENABLED=false
KAMIYO_OPERATOR_KEYPAIR_PATH=../../../token-launch/wallets/program-authority.json
KAMIYO_RUN_ONCE=false
KAMIYO_LOOP_INTERVAL_SECONDS=3600
KAMIYO_RPC_READ_TIMEOUT_MS=8000
KAMIYO_RPC_READ_RETRIES=4
KAMIYO_TICK_SOFT_TIMEOUT_BUFFER_SECONDS=60
KAMIYO_TICK_MIN_REMAINING_MS_FOR_SWARM_AGENT=25000
KAMIYO_TICK_MIN_REMAINING_MS_FOR_LLM=60000
KAMIYO_ANTHROPIC_REQUEST_TIMEOUT_MS=45000

KAMIYO_SWARM_ENABLED=true
KAMIYO_SWARM_PROPOSE_ONLY=false
KAMIYO_SWARM_JOB_INTAKE_ENABLED=true
KAMIYO_SWARM_JOB_EXECUTION_ENABLED=true
KAMIYO_SWARM_JOB_EXECUTIONS_PER_TICK=4
KAMIYO_SWARM_JOB_REQUIRE_EXPECTED_REWARD=true

KAMIYO_SWARM_LEAD_CONVERSION_ENABLED=true
KAMIYO_SWARM_LEAD_CONVERSION_SIMULATE_ONLY=false
KAMIYO_SWARM_LEAD_CONTRACT_VALIDATION_ENABLED=true

KAMIYO_SWARM_ROLLBACK_ENABLED=true
KAMIYO_SWARM_CIRCUIT_BREAKER_ENABLED=true

KAMIYO_SWARM_REVENUE_REPORT_ENABLED=true
KAMIYO_SWARM_REVENUE_REPORT_INTERVAL_MINUTES=15

KAMIYO_SWARM_SLO_REPORT_ENABLED=true
KAMIYO_SWARM_SLO_REPORT_WINDOW_DAYS=1
KAMIYO_SWARM_SLO_REPORT_INTERVAL_HOURS=1
KAMIYO_SWARM_SLO_ALERT_ENABLED=true
KAMIYO_SWARM_SLO_ALERT_COOLDOWN_HOURS=1

KAMIYO_METRICS_HTTP_ENABLED=true
KAMIYO_METRICS_HTTP_HOST=127.0.0.1
KAMIYO_METRICS_HTTP_PORT=9464
KAMIYO_METRICS_HTTP_PATH=/metrics
