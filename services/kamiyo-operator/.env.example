# Kamiyo Operator - example config
#
# Notes:
# - Default is safe: propose-only, no on-chain writes unless you explicitly enable it.
# - Never commit real keys.

# --- Required ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-20250514
ANTHROPIC_TEMPERATURE=0.3
ANTHROPIC_TOOL_CHOICE=auto
ANTHROPIC_DISABLE_PARALLEL_TOOL_USE=false
ANTHROPIC_THINKING_BUDGET_TOKENS=0

# --- Solana ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Operator signing key (one of these)
KAMIYO_OPERATOR_KEYPAIR_PATH=
# KAMIYO_OPERATOR_PRIVATE_KEY=

# --- Agent Identity ---
KAMIYO_IDENTITY=kyoshin
KAMIYO_AGENT_NAME=kyoshin
KAMIYO_AUTO_CREATE_AGENT=false
KAMIYO_AGENT_TYPE=Service
KAMIYO_AGENT_STAKE_SOL=0.5

# --- Token / Fees (optional until mint exists) ---
KAMIYO_TARGET_MINT=
KAMIYO_FEE_VAULT=

# --- Behavior ---
KAMIYO_MODE=propose
KAMIYO_RUN_ONCE=true
KAMIYO_STUCK_TICK_TIMEOUT_MINUTES=70
KAMIYO_LOOP_INTERVAL_SECONDS=3600
KAMIYO_ANNOUNCE_CHANNELS=x,telegram

# --- Budgets / Guardrails ---
KAMIYO_SOL_DAILY_CAP=0.10
KAMIYO_SOL_PER_TX_CAP=0.02
KAMIYO_MAX_TX_PER_DAY=25
KAMIYO_MAX_FEE_CLAIMS_PER_DAY=1
KAMIYO_AUTO_CLAIM_ENABLED=true
KAMIYO_AUTO_CLAIM_MIN_LAMPORTS=1000000

KAMIYO_LLM_MAX_TURNS_PER_DAY=24
KAMIYO_LLM_MAX_INPUT_TOKENS_PER_DAY=150000
KAMIYO_LLM_MAX_OUTPUT_TOKENS_PER_DAY=30000

KAMIYO_MAX_TURNS_PER_TICK=6
KAMIYO_MAX_OUTPUT_TOKENS_PER_TURN=2048

# --- Storage (gitignored) ---
KAMIYO_DB_PATH=output/kamiyo-operator/state.db
KAMIYO_OUTBOX_DIR=output/kamiyo-operator/outbox

# --- Alerts ---
KAMIYO_ALERT_STALE_MINUTES=70
KAMIYO_ALERT_RUNNING_STALE_MINUTES=70
KAMIYO_ALERT_CLAIM_ERROR_LOOKBACK_HOURS=24
