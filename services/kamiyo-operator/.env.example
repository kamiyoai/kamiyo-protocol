# Kamiyo Operator - example config
#
# Notes:
# - Default is safe: propose-only, no on-chain writes unless you explicitly enable it.
# - Never commit real keys.

# --- Required ---
ANTHROPIC_API_KEY=
KAMIYO_LLM_ENABLED=true
ANTHROPIC_MODEL=claude-opus-4-20250514
ANTHROPIC_TEMPERATURE=0.3
ANTHROPIC_TOOL_CHOICE=auto
ANTHROPIC_DISABLE_PARALLEL_TOOL_USE=false
ANTHROPIC_THINKING_BUDGET_TOKENS=1024

# --- Solana ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional comma-separated fallback RPC endpoints used for read-path failover.
SOLANA_RPC_FALLBACK_URLS=
KAMIYO_RPC_READ_TIMEOUT_MS=12000
KAMIYO_RPC_READ_RETRIES=2

# Operator signing key (one of these)
KAMIYO_OPERATOR_KEYPAIR_PATH=
# KAMIYO_OPERATOR_PRIVATE_KEY=

# --- Agent Identity ---
KAMIYO_IDENTITY=kamiyo-agent
KAMIYO_AGENT_NAME=kamiyo-agent
KAMIYO_AUTO_CREATE_AGENT=false
KAMIYO_AGENT_TYPE=Service
KAMIYO_AGENT_STAKE_SOL=0.5

# --- Token / Fees (optional until mint exists) ---
KAMIYO_TARGET_MINT=
KAMIYO_FEE_VAULT=
KAMIYO_STAKING_POOL=9mEd5iRcdbNUwaCmkPqYggLfg25B2DsTn1w6gNrgvC9d
KAMIYO_FUNDRY_API_BASE_URL=https://fundry.collaterize.com
KAMIYO_FUNDRY_HTTP_RETRIES=3
KAMIYO_FUNDRY_HTTP_BASE_BACKOFF_MS=350
KAMIYO_FUNDRY_HTTP_MAX_BACKOFF_MS=5000
KAMIYO_FUNDRY_METRICS_WINDOW_MINUTES=60
KAMIYO_AGENT_STAKING_POOL=4bKRU8AGUsgaSLTr5eSNyPKcJCaS5vY4Fwm58mzDjV2v
# Optional separate signer for Kamiyo Agent staking claims/routing. If unset, operator signer is used.
KAMIYO_AGENT_CLAIMER_KEYPAIR_PATH=
# KAMIYO_AGENT_CLAIMER_PRIVATE_KEY=
KAMIYO_PRIME_DIRECTIVE=Work for $KAMIYO: maximize SOL fees/revenue and route that SOL into the $KAMIYO staking pool so $KAMIYO stakers are paid.
# --- DKG activity publishing (optional) ---
KAMIYO_DKG_ACTIVITY_ENABLED=false
KAMIYO_DKG_ENDPOINT=
KAMIYO_DKG_PORT=8900
KAMIYO_DKG_BLOCKCHAIN=base:8453
KAMIYO_DKG_PRIVATE_KEY=
# Discover this value from chain:
# pnpm --filter @kamiyo/agent-paranet run discover-paranet-ual
KAMIYO_DKG_PARANET_UAL=
# Optional override. Defaults to Kamiyo Agent claimer public key.
# Global ID format: eip155:{chainId}:0x{address}:{agentId}
KAMIYO_DKG_AGENT_ID=
KAMIYO_DKG_AUDIT_SOURCE=kamiyo-operator
KAMIYO_DKG_JURISDICTION=global
KAMIYO_DKG_EPOCHS=12
KAMIYO_DKG_RATE_LIMIT_COOLDOWN_SECONDS=600
# --- Meishi trust layer (on-chain passport + mandate + baseline audit) ---
KAMIYO_MEISHI_ENABLED=true
KAMIYO_MEISHI_PROGRAM_ID=
# Optional alternate Kamiyo program used for Meishi-compatible agent identity.
# If your active agent PDA fails Meishi create with AgentIdentityInvalid, set this to the Meishi-compatible Kamiyo program.
KAMIYO_MEISHI_AGENT_PROGRAM_ID=
# Only applies in execute mode. Propose mode never auto-creates agent identities.
KAMIYO_MEISHI_AUTO_CREATE_AGENT=true
KAMIYO_MEISHI_JURISDICTION=global
KAMIYO_MEISHI_AUTO_CREATE_PASSPORT=true
KAMIYO_MEISHI_AUTO_SET_MANDATE=true
KAMIYO_MEISHI_AUTO_BASELINE_AUDIT=true
KAMIYO_MEISHI_BASELINE_SCORE=650
KAMIYO_MEISHI_MANDATE_DURATION_DAYS=30
KAMIYO_MEISHI_TX_LIMIT_USD=500
KAMIYO_MEISHI_DAILY_LIMIT_USD=2500
KAMIYO_MEISHI_MONTHLY_LIMIT_USD=25000
KAMIYO_MEISHI_HUMAN_APPROVAL_USD=250
KAMIYO_MEISHI_FINDINGS_PREFIX=urn:kamiyo:meishi:kamiyo-agent
# Optional exact 32-byte hex values (64 hex chars)
KAMIYO_MEISHI_CATEGORY_WHITELIST_HEX=
KAMIYO_MEISHI_MERCHANT_WHITELIST_HEX=

# --- Behavior ---
KAMIYO_MODE=propose
KAMIYO_RUN_ONCE=true
KAMIYO_LOCK_PATH=output/kamiyo-operator/runner.lock
KAMIYO_STUCK_TICK_TIMEOUT_MINUTES=70
KAMIYO_TICK_TIMEOUT_MINUTES=10
KAMIYO_TICK_SOFT_TIMEOUT_BUFFER_SECONDS=45
KAMIYO_TICK_MIN_REMAINING_MS_FOR_SWARM_AGENT=30000
KAMIYO_TICK_MIN_REMAINING_MS_FOR_LLM=75000
KAMIYO_LOOP_INTERVAL_SECONDS=3600
KAMIYO_METRICS_HTTP_ENABLED=false
KAMIYO_METRICS_HTTP_HOST=127.0.0.1
KAMIYO_METRICS_HTTP_PORT=9464
KAMIYO_METRICS_HTTP_PATH=/metrics
KAMIYO_SWARM_ENABLED=false
KAMIYO_SWARM_PROPOSE_ONLY=true
KAMIYO_SWARM_REGISTRY_PATH=output/kamiyo-operator/swarm.registry.json
KAMIYO_SWARM_MISSIONS_PER_TICK=3
KAMIYO_SWARM_MAX_ACTIVE_AGENTS=5
KAMIYO_SWARM_JOB_INTAKE_ENABLED=true
KAMIYO_SWARM_JOB_FEED_PATH=output/kamiyo-operator/swarm.jobs.json
# Comma-separated JSON feed URLs for external opportunity sources.
KAMIYO_SWARM_JOB_FEED_URLS=
KAMIYO_SWARM_RELEVANCE_FEED_URL=
KAMIYO_SWARM_RELEVANCE_API_KEY=
KAMIYO_SWARM_RELEVANCE_AUTH_HEADER=authorization
KAMIYO_SWARM_AGENTAI_FEED_URL=
KAMIYO_SWARM_AGENTAI_API_KEY=
KAMIYO_SWARM_AGENTAI_AUTH_HEADER=authorization
KAMIYO_SWARM_KORE_FEED_URL=
KAMIYO_SWARM_KORE_API_KEY=
KAMIYO_SWARM_KORE_AUTH_HEADER=authorization
KAMIYO_SWARM_JOB_MAX_OPEN=12
KAMIYO_SWARM_JOB_MIN_REWARD_USD=5
KAMIYO_SWARM_LEAD_CONVERSION_ENABLED=true
KAMIYO_SWARM_LEAD_CONVERSION_MAX_PER_TICK=4
KAMIYO_SWARM_LEAD_CONVERSION_DEFAULT_PAYOUT_USD=12
KAMIYO_SWARM_LEAD_CONVERSION_REQUIRE_ENDPOINT=true
KAMIYO_SWARM_LEAD_CONVERSION_SIMULATE_ONLY=false
KAMIYO_SWARM_LEAD_CONVERSION_MIN_CONFIDENCE=0.6
KAMIYO_SWARM_LEAD_CONTRACT_VALIDATION_ENABLED=true
KAMIYO_SWARM_SOURCE_FEEDBACK_WINDOW_HOURS=168
KAMIYO_SWARM_SOURCE_FEEDBACK_MIN_SAMPLES=3
KAMIYO_SWARM_SOL_PRICE_USD=150
KAMIYO_SWARM_JOB_FETCH_TIMEOUT_MS=8000
KAMIYO_SWARM_JOB_EXECUTION_ENABLED=true
KAMIYO_SWARM_JOB_EXECUTIONS_PER_TICK=2
KAMIYO_SWARM_JOB_HTTP_TIMEOUT_MS=20000
KAMIYO_SWARM_JOB_MIN_MARGIN_SOL=0.0005
KAMIYO_SWARM_JOB_ESTIMATED_FEE_SOL=0.00001
KAMIYO_SWARM_JOB_REQUIRE_EXPECTED_REWARD=false
KAMIYO_SWARM_X402_ENABLED=true
KAMIYO_SWARM_X402_MAX_PRICE_USD=2
KAMIYO_SWARM_X402_PREFERRED_NETWORK=solana:mainnet
KAMIYO_SWARM_X402_FACILITATOR_POLICY=prefer-kamiyo
KAMIYO_SWARM_CIRCUIT_BREAKER_ENABLED=true
KAMIYO_SWARM_CIRCUIT_NEG_MARGIN_STREAK=3
KAMIYO_SWARM_CIRCUIT_COOLDOWN_MINUTES=180
KAMIYO_SWARM_CIRCUIT_STATE_KEEP_DAYS=30
KAMIYO_SWARM_REVENUE_REPORT_ENABLED=true
KAMIYO_SWARM_REVENUE_REPORT_INTERVAL_MINUTES=60
KAMIYO_SWARM_SLO_REPORT_ENABLED=true
KAMIYO_SWARM_SLO_REPORT_WINDOW_DAYS=30
KAMIYO_SWARM_SLO_REPORT_INTERVAL_HOURS=24
KAMIYO_SWARM_SLO_ALERT_ENABLED=true
KAMIYO_SWARM_SLO_ALERT_COOLDOWN_HOURS=6
KAMIYO_SWARM_SLO_ALERT_WEBHOOK_URL=
KAMIYO_SWARM_SLO_ALERT_WEBHOOK_SECRET=
KAMIYO_SWARM_SLO_ALERT_WEBHOOK_TIMEOUT_MS=8000
KAMIYO_SWARM_ROLLBACK_ENABLED=true
KAMIYO_SWARM_ROLLBACK_EVAL_INTERVAL_HOURS=24
KAMIYO_SWARM_ROLLBACK_WINDOW_DAYS=7
KAMIYO_SWARM_ROLLBACK_NET_SOL_TRIGGER=-0.02
KAMIYO_SWARM_ROLLBACK_RECOVERY_NET_SOL=0
KAMIYO_SWARM_ROLLBACK_MIN_JOBS=5
KAMIYO_SWARM_ROLLBACK_SOURCE_MIN_JOBS=2
KAMIYO_SWARM_ROLLBACK_MAX_DISABLED_SOURCES=2
KAMIYO_SWARM_ROLLBACK_COOLDOWN_HOURS=24
KAMIYO_SWARM_WEEKLY_SUMMARY_ENABLED=true
KAMIYO_SWARM_WEEKLY_SUMMARY_INTERVAL_HOURS=168
KAMIYO_RETENTION_ENABLED=true
KAMIYO_RETENTION_INTERVAL_MINUTES=360
KAMIYO_RETENTION_TICKS_DAYS=30
KAMIYO_RETENTION_OBSERVATIONS_DAYS=30
KAMIYO_RETENTION_ACTIONS_DAYS=30
KAMIYO_RETENTION_LLM_USAGE_DAYS=30
KAMIYO_RETENTION_OUTBOX_DAYS=14
KAMIYO_RETENTION_OUTBOX_MAX_FILES=3000
KAMIYO_ANNOUNCE_CHANNELS=x,telegram

# --- Budgets / Guardrails ---
KAMIYO_SOL_DAILY_CAP=0.10
KAMIYO_SOL_PER_TX_CAP=0.02
KAMIYO_MAX_TX_PER_DAY=25
KAMIYO_MAX_FEE_CLAIMS_PER_DAY=1
KAMIYO_AUTO_CLAIM_ENABLED=true
KAMIYO_AUTO_CLAIM_MIN_LAMPORTS=1000000
KAMIYO_AGENT_AUTO_CLAIM_ENABLED=true
KAMIYO_AGENT_AUTO_CLAIM_MIN_LAMPORTS=0
KAMIYO_AGENT_AUTO_CLAIM_MAX_PERIODS_PER_RUN=8
KAMIYO_AUTO_STAKE_ENABLED=true
KAMIYO_AUTO_STAKE_MIN_LAMPORTS=50000000
KAMIYO_AUTO_STAKE_RESERVE_LAMPORTS=200000000
KAMIYO_AUTO_STAKE_AVAILABLE_BPS=5000
KAMIYO_AUTO_STAKE_MAX_LAMPORTS_PER_TX=0
KAMIYO_AUTO_STAKE_MAX_FEEDS_PER_DAY=24

KAMIYO_LLM_MAX_TURNS_PER_DAY=24
KAMIYO_LLM_MAX_INPUT_TOKENS_PER_DAY=150000
KAMIYO_LLM_MAX_OUTPUT_TOKENS_PER_DAY=30000

KAMIYO_MAX_TURNS_PER_TICK=6
KAMIYO_MAX_OUTPUT_TOKENS_PER_TURN=2048
KAMIYO_ANTHROPIC_REQUEST_TIMEOUT_MS=60000

# --- Storage (gitignored) ---
KAMIYO_DB_PATH=output/kamiyo-operator/state.db
KAMIYO_OUTBOX_DIR=output/kamiyo-operator/outbox

# --- Alerts ---
KAMIYO_ALERT_STALE_MINUTES=70
KAMIYO_ALERT_RUNNING_STALE_MINUTES=70
KAMIYO_ALERT_CLAIM_ERROR_LOOKBACK_HOURS=24
KAMIYO_ALERT_STAKE_ERROR_LOOKBACK_HOURS=24
KAMIYO_ALERT_FUNDRY_LOOKBACK_HOURS=1
KAMIYO_ALERT_FUNDRY_MIN_ATTEMPTS=5
KAMIYO_ALERT_FUNDRY_MAX_ERROR_RATE=0.25
KAMIYO_ALERT_FUNDRY_MAX_429_COUNT=8
# Optional override for alert-runner node binary (useful for cron if multiple Node versions exist)
# KAMIYO_NODE_BIN=$HOME/.nvm/versions/node/v20.18.2/bin/node
