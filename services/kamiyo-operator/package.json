{
  "name": "@kamiyo/kamiyo-operator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous single-token operator agent (Claude) with verifiable on-chain receipts.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "tsx --test src/**/*.test.ts",
    "benchmark:autonomy": "node dist/scripts/autonomyBenchmarkReport.js",
    "soak:swarm": "node dist/scripts/swarmSoakTest.js",
    "proof:bundle": "node dist/scripts/aiProofBundle.js",
    "proof:24h": "node dist/scripts/aiProofBundle.js -- --hours 24 --min-ticks 300 --max-interventions 0 --max-gap-minutes 5",
    "proof:refresh": "node dist/scripts/swarmSoakTest.js -- --opportunities 2500 --iterations 10 --agents 8 && node dist/scripts/autonomyBenchmarkReport.js -- --days 1 && node dist/scripts/aiProofBundle.js -- --hours 24 --min-ticks 300 --max-interventions 0 --max-gap-minutes 5",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "check:alerts": "node dist/healthCheck.js",
    "cron:install-alerts": "bash scripts/install-alert-cron.sh",
    "daemon:install": "bash scripts/install-operator-launchd.sh",
    "daemon:status": "bash scripts/status-operator-launchd.sh",
    "daemon:uninstall": "bash scripts/uninstall-operator-launchd.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@coral-xyz/anchor": "^0.31.1",
    "@kamiyo/agent-paranet": "workspace:*",
    "@kamiyo/sdk": "workspace:*",
    "@kamiyo/x402-client": "workspace:*",
    "@meteora-ag/dynamic-fee-sharing-sdk": "^1.0.6",
    "@solana/web3.js": "^1.98.0",
    "better-sqlite3": "^11.0.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
