# Anthropic API Key
ANTHROPIC_API_KEY=

# xAI/Grok API Key (responses + image generation)
XAI_API_KEY=

# OpenAI API Key (optional - DALL-E 3 fallback for images)
OPENAI_API_KEY=

# Twitter API v2 Credentials
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Your Twitter user ID for DM approvals (get from twitter.com/settings/your_twitter_data)
OWNER_TWITTER_ID=

# Approval mode: auto | dm | hybrid
# auto = Claude self-reviews and decides
# dm = require your approval via DM
# hybrid = auto-approve high quality, DM for uncertain (recommended)
APPROVAL_MODE=hybrid

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API Key (optional - enriches wallet lookups with token metadata)
HELIUS_API_KEY=

# Treasury wallet for subscription payments (SOL)
TREASURY_WALLET=

# Actions/Blinks server
ACTIONS_HOST=https://companion.kamiyo.ai
ACTIONS_PORT=3001

# Data directory for persistent database (use /data on Render with disk)
DATA_DIR=./data
