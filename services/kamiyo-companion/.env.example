# Anthropic API Key
ANTHROPIC_API_KEY=

# xAI/Grok API Key (optional - enables combined Claude+Grok responses)
XAI_API_KEY=

# Twitter API v2 Credentials
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API Key (optional - enriches wallet lookups with token metadata)
HELIUS_API_KEY=

# Image generation (optional - enables meme generation)
TOGETHER_API_KEY=
REPLICATE_API_KEY=

# Treasury wallet for subscription payments (SOL)
TREASURY_WALLET=

# Actions/Blinks server
ACTIONS_HOST=https://companion.kamiyo.ai
ACTIONS_PORT=3001

# Approval API for autonomous posts
APPROVAL_PORT=3002
APPROVAL_API_KEY=your-secret-key

# Data directory for persistent database (use /data on Render with disk)
DATA_DIR=./data
