# Anthropic API Key
ANTHROPIC_API_KEY=

# xAI/Grok API Key (responses + image generation)
XAI_API_KEY=

# OpenAI API Key (optional - DALL-E 3 fallback for images)
OPENAI_API_KEY=

# Twitter API v2 Credentials
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Your Twitter user ID for DM approvals (get from twitter.com/settings/your_twitter_data)
OWNER_TWITTER_ID=

# Approval mode: auto | dm | hybrid
# auto = Claude self-reviews and decides
# dm = require your approval via DM
# hybrid = auto-approve high quality, DM for uncertain (recommended)
APPROVAL_MODE=hybrid

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana keypair for agent identity (optional - enables on-chain features)
# Generate with: solana-keygen new -o keypair.json
SOLANA_KEYPAIR_PATH=./keypair.json

# Helius API Key (optional - enriches wallet lookups with token metadata)
HELIUS_API_KEY=

# Treasury wallet for subscription payments (SOL)
TREASURY_WALLET=

# Actions/Blinks server
ACTIONS_HOST=https://companion.kamiyo.ai
ACTIONS_PORT=3001

# Holder API (1M+ token holders)
# Set to true to enable REST API endpoints alongside the bot
API_ENABLED=false
API_PORT=3001

# Data directory for persistent database (use /data on Render with disk)
DATA_DIR=./data

# ===== ORGANIC GROWTH SETTINGS =====

# Accounts to monitor (comma-separated, no @ symbols)
# Default: elonmusk,sama,pmarca,VitalikButerin,tetsuoai,7etsuo,unusual_whales
MONITORED_ACCOUNTS=elonmusk,sama,VitalikButerin,tetsuoai,7etsuo

# Proactive engagement (replies to non-mentions)
# Set to true to reply to influencer tweets without being @mentioned
# Default: false (only respond when explicitly @mentioned)
PROACTIVE_REPLIES_ENABLED=false

# Strategic reply settings (only applies if proactive enabled)
AUTO_REPLY_ENABLED=true
AUTO_REPLY_MIN_SCORE=7
MAX_REPLIES_PER_HOUR=4

# Quote tweet settings
MAX_QUOTES_PER_DAY=3
