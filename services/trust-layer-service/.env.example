DATABASE_URL=postgresql://localhost:5432/kamiyo
TRUST_LAYER_BIND_ADDR=0.0.0.0:8095
TRUST_LAYER_KAFKA_BROKERS=localhost:9092
TRUST_LAYER_KAFKA_TOPIC=kamiyo.trust.events
TRUST_LAYER_KAFKA_COMPRESSION_TYPE=none
TRUST_LAYER_API_KEY=replace-with-strong-secret
TRUST_LAYER_API_KEYS=replace-current-key,replace-next-key
TRUST_LAYER_RELAY_BATCH_SIZE=100
TRUST_LAYER_RELAY_INTERVAL_MS=500
TRUST_LAYER_RELAY_STUCK_TIMEOUT_SECS=120
TRUST_LAYER_RELAY_MAX_ATTEMPTS=16
TRUST_LAYER_REPLAY_BATCH_SIZE=5000
TRUST_LAYER_DEAD_LETTER_REDRIVE_LIMIT=100
TRUST_LAYER_DEAD_LETTER_RETENTION_SECS=604800
TRUST_LAYER_DEAD_LETTER_SWEEP_LIMIT=1000

# Optional Kafka auth/TLS for production clusters
# TRUST_LAYER_KAFKA_SECURITY_PROTOCOL=SASL_SSL
# TRUST_LAYER_KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# TRUST_LAYER_KAFKA_SASL_USERNAME=service-account
# TRUST_LAYER_KAFKA_SASL_PASSWORD=secret
# TRUST_LAYER_KAFKA_SSL_CA_LOCATION=/etc/ssl/certs/ca.pem
