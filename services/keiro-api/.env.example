# ── Required ─────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Server ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/keiro

# ── AI Models ────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
KEIRO_SEMANTIC_ACCEPT_THRESHOLD=0.35

# ── Receipts ─────────────────────────────────────────────────────────
RECEIPT_SIGNING_KEY=
