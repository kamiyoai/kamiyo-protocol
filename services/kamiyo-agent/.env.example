# ── Solana ────────────────────────────────────────────────────────────
SOLANA_RPC_URL=
SOLANA_RPC_FALLBACK_URLS=
KAMIYO_RPC_READ_TIMEOUT_MS=12000
KAMIYO_RPC_READ_RETRIES=2

# ── Operator Identity ───────────────────────────────────────────────
KAMIYO_OPERATOR_KEYPAIR_PATH=
# OR
KAMIYO_OPERATOR_PRIVATE_KEY=

# ── Execution Mode ──────────────────────────────────────────────────
KAMIYO_MODE=propose
KAMIYO_EXECUTION_STAGE=canary_0
KAMIYO_EXECUTION_HARD_STOP=false
KAMIYO_RUN_ONCE=false
KAMIYO_LOOP_INTERVAL_SECONDS=180

# ── Storage ──────────────────────────────────────────────────────────
KAMIYO_DB_PATH=output/kamiyo-agent/state.db
KAMIYO_OUTBOX_DIR=output/kamiyo-agent/outbox

# ── Spending Caps ────────────────────────────────────────────────────
KAMIYO_SOL_DAILY_CAP=0.1
KAMIYO_SOL_PER_TX_CAP=0.02
KAMIYO_MAX_TX_PER_DAY=25

# ── Staking ──────────────────────────────────────────────────────────
KAMIYO_STAKING_POOL=
KAMIYO_AUTO_STAKE_ENABLED=true

# ── Fee Claims ───────────────────────────────────────────────────────
KAMIYO_FEE_VAULT=
KAMIYO_AUTO_CLAIM_ENABLED=true

# ── Swarm ────────────────────────────────────────────────────────────
KAMIYO_SWARM_ENABLED=true
KAMIYO_SWARM_MISSIONS_PER_TICK=3
KAMIYO_SWARM_MAX_ACTIVE_AGENTS=5
KAMIYO_SWARM_JOB_INTAKE_ENABLED=true
KAMIYO_SWARM_JOB_EXECUTION_ENABLED=true

# ── Revenue Policy ──────────────────────────────────────────────────
KAMIYO_REVENUE_POLICY_ENABLED=true
KAMIYO_REVENUE_SETTLE_INTERVAL_MINUTES=30

# ── HTTP API ─────────────────────────────────────────────────────────
KAMIYO_AGENT_HTTP_ENABLED=true
KAMIYO_AGENT_HTTP_HOST=0.0.0.0
KAMIYO_AGENT_HTTP_PORT=4020
KAMIYO_AGENT_HTTP_TOKEN=

# ── Kizuna Integration ──────────────────────────────────────────────
KAMIYO_FUNDRY_API_BASE_URL=
