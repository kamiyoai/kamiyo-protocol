{
  "name": "@kamiyo/autopilot",
  "version": "0.1.0",
  "description": "Headless autonomous dev loop: reads agent-labeled issues, drafts PRs via Claude Agent SDK",
  "main": "dist/index.js",
  "bin": {
    "kamiyo-autopilot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "run:issue": "tsx src/run-issue.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@anthropic-ai/sdk": "^0.77.0",
    "@octokit/rest": "^21.0.0",
    "dotenv": "^16.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
