# ── Required ─────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
GITHUB_TOKEN=
GITHUB_REPO=kamiyoai/kamiyo-protocol

# ── Runtime ──────────────────────────────────────────────────────────
CLAUDE_MODEL=hf.co/OBLITERATUS/gemma-4-E4B-it-OBLITERATED:Q5_K_M
AUTOPILOT_DB_PATH=.autopilot/agent.db
MAX_TURNS=30
DAILY_USD_MAX=0
RECONCILE_DELAY_HOURS=6
SELF_IMPROVE_ENABLED=true
SELF_IMPROVE_TASK_TYPE=autopilot_issue_resolution
SELF_IMPROVE_JUDGE_MODEL=hf.co/OBLITERATUS/gemma-4-E4B-it-OBLITERATED:Q5_K_M
SELF_IMPROVE_MIN_SAMPLES=5
SELF_IMPROVE_P_THRESHOLD=0.1

# ── Labels ───────────────────────────────────────────────────────────
AGENT_LABEL=agent
APPROVED_LABEL=agent-approved
HALT_LABEL=halt-autopilot
BOT_LOGIN=kamiyo-bot

# ── Safety ───────────────────────────────────────────────────────────
DRY_RUN=0
