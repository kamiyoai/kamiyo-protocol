# ── Required ─────────────────────────────────────────────────────────
SOLANA_RPC_URL=
FACILITATOR_PRIVATE_KEY=
TREASURY_WALLET=
DATABASE_URL=postgresql://localhost:5432/x402_facilitator

# ── Server ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Fee Configuration ───────────────────────────────────────────────
SETTLEMENT_FEE_BPS=
ESCROW_FEE_BPS=
DISPUTE_FEE_BPS=
MAX_SETTLEMENT_AMOUNT=

# ── Escrow ───────────────────────────────────────────────────────────
ESCROW_PROGRAM_ID=
MAX_PAYMENT_AGE_MS=

# ── Kizuna ───────────────────────────────────────────────────────────
KIZUNA_ENABLED=false
KIZUNA_SHADOW_MODE=false
KIZUNA_INTERNAL_TOKEN=
KIZUNA_ENTERPRISE_POOL_ID=
KIZUNA_FASTPATH_POOL_ID=
KIZUNA_KERNEL_URL=
KIZUNA_SECURED_ONLY=false

# ── Kizuna Fastpath ─────────────────────────────────────────────────
KIZUNA_FASTPATH_LTV_CAP_BPS=
KIZUNA_FASTPATH_MIN_HEALTH_FACTOR=

# ── Agent Registry ──────────────────────────────────────────────────
KIZUNA_AGENT_REGISTRY_CLUSTER=devnet
KIZUNA_AGENT_REGISTRY_RPC_URL=

# ── Wallet Control Plane ────────────────────────────────────────────
WALLET_CONTROL_PLANE_URL=
CREDITS_INTERNAL_URL=

# ── Base (EVM) ──────────────────────────────────────────────────────
BASE_RPC_URL=
BASE_FACILITATOR_KEY=
BASE_TREASURY_ADDRESS=

# ── Fairscale Trust Events ──────────────────────────────────────────
FAIRSCALE_TRUST_EVENTS_URL=
FAIRSCALE_TRUST_EVENTS_KEY=

# ── Privacy ─────────────────────────────────────────────────────────
PRIVACY_ENABLED=false
