{
  "name": "@kamiyo/daydreams",
  "version": "1.0.0",
  "deprecated": "Use @kamiyo/agents with Claude Agent SDK instead. This package is maintained for existing users only.",
  "description": "[DEPRECATED] Daydreams extension for Kamiyo payments and ZK reputation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "homepage": "https://kamiyo.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamiyo-ai/kamiyo-protocol.git",
    "directory": "packages/kamiyo-daydreams"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "mcp-server": "node dist/mcp-server.js"
  },
  "keywords": [
    "daydreams",
    "daydreamsai",
    "ai-agents",
    "mcp",
    "model-context-protocol",
    "kamiyo",
    "payments",
    "escrow",
    "zk-reputation"
  ],
  "author": "KAMIYO <dev@kamiyo.ai>",
  "dependencies": {
    "@kamiyo/agent-core": "workspace:*",
    "@kamiyo/sdk": "workspace:*",
    "@kamiyo/middleware": "workspace:*",
    "@solana/web3.js": "^1.95.8",
    "@coral-xyz/anchor": "^0.31.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.10",
    "jest": "^30.2.0",
    "ts-jest": "^29.2.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "@daydreamsai/core": ">=0.1.0",
    "@coinbase/coinbase-sdk": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@daydreamsai/core": {
      "optional": true
    },
    "@coinbase/coinbase-sdk": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "daydreams": {
    "extension": "kamiyoExtension",
    "contexts": [
      "kamiyoPaymentContext",
      "kamiyoServiceContext",
      "kamiyoDisputeContext",
      "kamiyoReputationContext"
    ],
    "actions": [
      "kamiyo.consumeAPI",
      "kamiyo.createEscrow",
      "kamiyo.fileDispute",
      "kamiyo.discoverAPIs",
      "kamiyo.checkBalance",
      "kamiyo.getPaymentHistory",
      "kamiyo.getQualityStats",
      "kamiyo.generateCommitment",
      "kamiyo.proveReputation",
      "kamiyo.verifyProof",
      "kamiyo.getReputationTier",
      "kamiyo.canProveTier",
      "kamiyo.getVerifiedPeers"
    ],
    "mcp": {
      "tools": 13,
      "transport": ["stdio", "sse"]
    }
  }
}
