{
  "name": "@kamiyo/cdp",
  "version": "0.1.0",
  "type": "module",
  "description": "Coinbase CDP wallet + policy integration for Kamiyo agentic wallets (server + embedded end-users).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
