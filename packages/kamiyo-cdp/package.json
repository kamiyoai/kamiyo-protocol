    "test:watch": "vitest"
  },
  "author": "KAMIYO",
  "license": "MIT",
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.43.1",
    "@kamiyo/meishi": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.24",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
