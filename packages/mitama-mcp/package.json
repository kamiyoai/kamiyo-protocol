{
  "name": "@mitama/mcp-server",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for Mitama agent identity and conflict resolution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mitama-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp src/idl/mitama.json dist/idl/mitama.json 2>/dev/null || true",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run test:integration",
    "test:integration": "tsx tests/test-integration.ts",
    "test:mcp": "tsx tests/test-mcp-tools.ts",
    "test:all": "npm run test:mcp && npm run test:integration",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "solana",
    "anchor",
    "mitama",
    "agent-identity",
    "conflict-resolution"
  ],
  "author": "KAMIYO",
  "license": "BUSL-1.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@coral-xyz/anchor": "^0.31.1",
    "@modelcontextprotocol/sdk": "^1.21.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0",
    "borsh": "^2.0.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bs58": "^5.0.0",
    "@types/node": "^20.19.24",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
