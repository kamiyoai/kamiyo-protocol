{
  "name": "@kamiyo/eliza-dkg",
  "version": "1.0.0",
  "description": "Bridge between KAMIYO escrow/reputation and OriginTrail DKG for ElizaOS agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "homepage": "https://kamiyo.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamiyo-ai/kamiyo-protocol.git",
    "directory": "packages/kamiyo-eliza-dkg"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "DKG_ENDPOINT": {
        "type": "string",
        "description": "DKG node endpoint URL",
        "default": "https://your-dkg-node.example.com"
      },
      "DKG_PORT": {
        "type": "number",
        "description": "DKG node port",
        "default": 8900
      },
      "DKG_BLOCKCHAIN": {
        "type": "string",
        "description": "Blockchain network (base:8453, gnosis:100, otp:2043)",
        "default": "base:8453"
      },
      "DKG_PRIVATE_KEY": {
        "type": "string",
        "description": "Private key for signing DKG transactions"
      },
      "KAMIYO_NETWORK": {
        "type": "string",
        "description": "Solana network: mainnet, devnet, or localnet",
        "default": "mainnet"
      },
      "SOLANA_PRIVATE_KEY": {
        "type": "string",
        "description": "Base64-encoded Solana keypair for signing transactions"
      },
      "DKG_EPOCHS": {
        "type": "number",
        "description": "Number of epochs for DKG asset storage",
        "default": 2
      },
      "AUTO_PUBLISH_QUALITY": {
        "type": "boolean",
        "description": "Auto-publish quality attestations to DKG",
        "default": true
      },
      "AUTO_PUBLISH_DISPUTES": {
        "type": "boolean",
        "description": "Auto-publish dispute outcomes to DKG",
        "default": true
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "keywords": [
    "elizaos",
    "eliza",
    "ai-agents",
    "kamiyo",
    "origintrail",
    "dkg",
    "knowledge-graph",
    "escrow",
    "reputation",
    "x402"
  ],
  "author": "KAMIYO <dev@kamiyo.ai>",
  "dependencies": {
    "@kamiyo/agent-paranet": "workspace:*",
    "@kamiyo/eliza": "workspace:*",
    "@kamiyo/dkg-quality-oracle": "workspace:*",
    "@kamiyo/sdk": "workspace:*",
    "@kamiyo/x402-client": "workspace:*",
    "@kamiyo/solana-privacy": "workspace:*",
    "dkg.js": "^8.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@elizaos/core": ">=1.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
