{
  "name": "@kamiyo/mcp-server",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for autonomous agent payments. Escrow, quality assessment, dispute resolution, and x402 support for AI agents.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./solana/client": {
      "types": "./dist/solana/client.d.ts",
      "import": "./dist/solana/client.js"
    },
    "./solana/anchor": {
      "types": "./dist/solana/anchor.d.ts",
      "import": "./dist/solana/anchor.js"
    },
    "./truth-court": {
      "types": "./dist/truth-court/index.d.ts",
      "import": "./dist/truth-court/index.js"
    }
  },
  "bin": {
    "kamiyo-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/idl && cp src/idl/x402_escrow.json dist/idl/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "demo:event-horizon": "tsx src/demo/event-horizon.ts",
    "demo:event-horizon:mock": "tsx src/demo/event-horizon.ts --mock",
    "demo:event-horizon:live": "tsx src/demo/event-horizon.ts --live",
    "demo:event-horizon:gauntlet": "tsx src/demo/event-horizon-gauntlet.ts",
    "demo:event-horizon:gauntlet:mock": "tsx src/demo/event-horizon-gauntlet.ts --mock",
    "demo:event-horizon:gauntlet:live": "tsx src/demo/event-horizon-gauntlet.ts --live",
    "demo:event-horizon:gauntlet:verify": "tsx src/demo/event-horizon-gauntlet-verify.ts",
    "test": "npm run test:integration",
    "test:integration": "tsx tests/test-integration.ts",
    "test:truth-court": "tsx tests/test-truth-court.ts",
    "test:truth-court:gauntlet": "tsx tests/test-truth-court-gauntlet.ts",
    "test:truth-court:attestation": "tsx tests/test-truth-court-attestation.ts",
    "test:tool-parity": "node scripts/check-tool-parity.mjs",
    "smoke:stdio": "node scripts/smoke-stdio.mjs",
    "test:mcp": "tsx tests/test-mcp-tools.ts",
    "test:live-config": "tsx tests/test-live-config.ts",
    "test:live-cdp-transaction": "tsx tests/test-live-cdp-transaction.ts",
    "test:kamino": "tsx tests/test-kamino.ts",
    "test:all": "npm run test:tool-parity && npm run test:mcp && npm run test:integration && npm run test:truth-court && npm run test:truth-court:gauntlet && npm run test:truth-court:attestation",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "autonomous-agent",
    "agent-wallet",
    "agent-payments",
    "escrow",
    "dispute-resolution",
    "x402",
    "solana",
    "claude",
    "langchain",
    "ai-tools"
  ],
  "author": "KAMIYO",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@coral-xyz/anchor": "^0.31.1",
    "@kamiyo/agent-paranet": "workspace:*",
    "@kamiyo/cdp": "workspace:*",
    "@kamiyo/x402-client": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.21.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0",
    "borsh": "^2.0.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bs58": "^5.0.0",
    "@types/node": "^20.19.24",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "prettier": "^3.3.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
