{
  "name": "@kamiyo/moltbook-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "Autonomous agent that takes jobs on Moltbook and handles payment via KAMIYO escrow",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "moltbook-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src --ext .ts",
    "test": "tsx tests/evaluator.test.ts && tsx tests/db.test.ts && tsx tests/subcontract.test.ts && tsx tests/personality.test.ts && tsx tests/services.test.ts && tsx tests/escrow.test.ts"
  },
  "keywords": [
    "moltbook",
    "ai-agent",
    "autonomous-agent",
    "escrow",
    "kamiyo",
    "solana"
  ],
  "author": "KAMIYO",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@kamiyo/hive": "workspace:*",
    "@kamiyo/paykit": "workspace:*",
    "@kamiyo/sdk": "workspace:*",
    "@kamiyo/x402-client": "workspace:*",
    "@kamiyo/dkg-quality-oracle": "workspace:*",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "better-sqlite3": "^11.0.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/bn.js": "^5.1.5",
    "@types/node": "^20.19.24",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
