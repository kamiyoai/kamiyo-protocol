{
  "name": "@kamiyo/surfpool",
  "version": "0.2.0",
  "description": "Production-grade Surfpool testing framework for Solana programs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamiyo-ai/kamiyo-protocol.git",
    "directory": "packages/kamiyo-surfpool"
  },
  "homepage": "https://github.com/kamiyo-ai/kamiyo-protocol/tree/main/packages/kamiyo-surfpool",
  "bugs": {
    "url": "https://github.com/kamiyo-ai/kamiyo-protocol/issues"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && npm run build:esm",
    "build:esm": "tsc -p tsconfig.esm.json --outDir dist/esm && node -e \"const fs=require('fs');const files=fs.readdirSync('dist/esm').filter(f=>f.endsWith('.js'));files.forEach(f=>{fs.renameSync('dist/esm/'+f,'dist/'+f.replace('.js','.mjs'))});fs.rmSync('dist/esm',{recursive:true})\"",
    "test": "jest --passWithNoTests",
    "test:examples": "ts-node examples/basic-simulation.ts",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.mjs",
      "require": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./strategy": {
      "import": "./dist/strategy.mjs",
      "require": "./dist/strategy.js",
      "types": "./dist/strategy.d.ts"
    },
    "./preflight": {
      "import": "./dist/preflight.mjs",
      "require": "./dist/preflight.js",
      "types": "./dist/preflight.d.ts"
    }
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.0"
  },
  "peerDependencies": {
    "@kamiyo/sdk": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@kamiyo/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.0.0",
    "jest": "^30.2.0",
    "@types/jest": "^30.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.0"
  },
  "files": [
    "dist/**/*",
    "examples/**/*",
    "README.md"
  ],
  "keywords": [
    "solana",
    "surfpool",
    "simulation",
    "testing",
    "devnet",
    "localnet",
    "mainnet-fork",
    "time-travel",
    "strategy-testing",
    "preflight",
    "transaction-simulation",
    "anchor",
    "solana-testing"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
