{
  "name": "kamiyo",
  "version": "0.1.0",
  "description": "Agent Identity and Conflict Resolution Protocol for Solana",
  "keywords": [
    "solana",
    "agents",
    "identity",
    "conflict-resolution",
    "escrow",
    "oracle",
    "web3"
  ],
  "homepage": "https://www.kamiyo.ai/",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamiyo-ai/kamiyo-protocol.git"
  },
  "license": "MIT",
  "author": "KAMIYO <susumu@kamiyo.ai>",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*",
    "services/*"
  ],
  "scripts": {
    "build": "anchor build && npm run build:sdk",
    "build:api": "pnpm --filter @kamiyo/meishi run build && pnpm --filter @kamiyo/sdk run build && pnpm --filter @kamiyo/x402-client run build && pnpm --filter @kamiyo/hive run build && pnpm --filter @kamiyo/agent-paranet run build && pnpm --filter @kamiyo/agent-core run build && pnpm --filter @kamiyo/daydreams run build && pnpm --filter @kamiyo/swarm-agents run build && pnpm --filter @kamiyo/settlement run build && pnpm --filter @kamiyo/agents run build && pnpm --filter kamiyo-companion run build",
    "build:program": "anchor build",
    "build:sdk": "pnpm --filter @kamiyo/meishi run build && pnpm --filter @kamiyo/sdk run build",
    "build:surfpool": "pnpm --filter @kamiyo/surfpool run build",
    "build:oracle": "pnpm --filter @kamiyo/hive run build && pnpm --filter @kamiyo/hyperliquid run build && cd services/oracle && npm install && npm run build",
    "build:kyoshin": "pnpm --filter @kamiyo/agent-paranet run build && pnpm --filter @kamiyo/settlement run build && pnpm --filter @kamiyo/agents run build && cd services/kyoshin && npm run build",
    "clean": "rm -rf target && cd packages/kamiyo-sdk && rm -rf dist",
    "test": "anchor test",
    "test:sdk": "pnpm --filter @kamiyo/sdk run test",
    "test:surfpool": "pnpm --filter @kamiyo/surfpool run test",
    "test:preflight": "pnpm --filter @kamiyo/surfpool run test",
    "lint": "eslint 'packages/*/src/**/*.ts' 'services/*/src/**/*.ts' --fix",
    "lint:check": "eslint 'packages/*/src/**/*.ts' 'services/*/src/**/*.ts'",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'services/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts' 'services/*/src/**/*.ts'",
    "lint:rust": "pnpm run lint:rust:fmt && pnpm run lint:rust:core",
    "lint:rust:fmt": "cargo fmt --all -- --check",
    "lint:rust:core": "cargo clippy -p kamiyo-trust-layer -p trust-layer-service -p kani-solana --all-targets --all-features -- -D warnings",
    "lint:rust:onchain:info": "cargo clippy -p kamiyo -p kamiyo-escrow -p kamiyo-staking -p kamiyo-governance -p kamiyo-transfer-hook -p hive -p kamiyo-fast-voting -p meishi --all-targets --all-features -- -A warnings",
    "format:rust": "cargo fmt --all",
    "build:meishi-compliance": "pnpm --filter @kamiyo/meishi run build && pnpm --filter @kamiyo/sdk run build && pnpm --filter @kamiyo/meishi-compliance run build",
    "test:meishi:integration": "./scripts/run-meishi-integration.sh",
    "seed:dkg": "tsx scripts/seed-dkg-trust-graph.ts",
    "show:trustlayer": "NODE_OPTIONS='--require ./scripts/suppress-bigint-warning.cjs' tsx scripts/show-trustlayer-live.ts",
    "live:manual": "NODE_OPTIONS='--require ./scripts/suppress-bigint-warning.cjs' tsx scripts/show-trustlayer-manual.ts",
    "live:manual:prep": "NODE_OPTIONS='--require ./scripts/suppress-bigint-warning.cjs' tsx scripts/show-trustlayer-manual.ts prep",
    "live:manual:agent": "NODE_OPTIONS='--require ./scripts/suppress-bigint-warning.cjs' tsx scripts/show-trustlayer-manual.ts agent",
    "live:manual:launch": "NODE_OPTIONS='--require ./scripts/suppress-bigint-warning.cjs' tsx scripts/show-trustlayer-manual.ts launch",
    "live:manual:proof": "NODE_OPTIONS='--require ./scripts/suppress-bigint-warning.cjs' tsx scripts/show-trustlayer-manual.ts proof",
    "live:manual:meishi": "NODE_OPTIONS='--require ./scripts/suppress-bigint-warning.cjs' tsx scripts/show-trustlayer-manual.ts meishi",
    "live:manual:status": "NODE_OPTIONS='--require ./scripts/suppress-bigint-warning.cjs' tsx scripts/show-trustlayer-manual.ts status",
    "live:manual:reset": "NODE_OPTIONS='--require ./scripts/suppress-bigint-warning.cjs' tsx scripts/show-trustlayer-manual.ts reset",
    "operator-log:new": "tsx scripts/operator-logbook.ts new",
    "operator-log:validate": "tsx scripts/operator-logbook.ts validate",
    "check:docs": "node scripts/check-doc-commands.mjs",
    "check:onboarding": "node scripts/check-service-onboarding.mjs",
    "check:mcp:parity": "pnpm --filter @kamiyo/mcp-server run test:tool-parity",
    "preflight:enterprise": "node scripts/enterprise-readiness.mjs --mode ci",
    "smoke:enterprise": "node scripts/enterprise-readiness.mjs --mode live",
    "audit:policy": "node scripts/check-security-policy.mjs",
    "audit": "pnpm audit && cargo audit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "@types/express-serve-static-core": "^4.19.8",
      "@types/bn.js": "4.11.6",
      "@solana/web3.js": "1.95.8",
      "fast-xml-parser": "^5.3.5",
      "form-data": "2.5.4"
    }
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@elizaos/plugin-trust": "1.2.1",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.8.5",
    "@meteora-ag/dynamic-fee-sharing-sdk": "^1.0.6",
    "@solana/spl-governance": "^0.3.28",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "1.95.8",
    "@sqds/multisig": "^2.1.4",
    "@types/chai": "^5.2.3",
    "@types/eventsource": "^3.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "chai": "^4.5.0",
    "circomlibjs": "^0.1.7",
    "eslint": "^8.57.0",
    "eventsource": "^4.1.0",
    "fastestsmallesttextencoderdecoder": "^1.0.22",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "snarkjs": "^0.7.6",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.3.0"
  }
}
