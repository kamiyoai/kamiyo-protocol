{
  "name": "kamiyo",
  "version": "0.1.0",
  "description": "Agent Identity and Conflict Resolution Protocol for Solana",
  "keywords": [
    "solana",
    "agents",
    "identity",
    "conflict-resolution",
    "escrow",
    "oracle",
    "web3"
  ],
  "homepage": "https://github.com/kamiyo-ai/kamiyo-protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamiyo-ai/kamiyo-protocol.git"
  },
  "license": "MIT",
  "author": "KAMIYO <susumu@kamiyo.ai>",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "anchor build && npm run build:sdk",
    "build:api": "pnpm --filter @kamiyo/sdk run build && pnpm --filter @kamiyo/kamiyo-mitama run build && pnpm --filter @kamiyo/x402-client run build && pnpm --filter @kamiyo/swarm-agents run build && pnpm --filter @kamiyo/blindfold run build && pnpm --filter kamiyo-companion run build",
    "build:program": "anchor build",
    "build:sdk": "pnpm --filter @kamiyo/sdk run build",
    "build:surfpool": "pnpm --filter @kamiyo/surfpool run build",
    "clean": "rm -rf target && cd packages/kamiyo-sdk && rm -rf dist",
    "test": "anchor test",
    "test:sdk": "pnpm --filter @kamiyo/sdk run test",
    "test:surfpool": "pnpm --filter @kamiyo/surfpool run test",
    "test:preflight": "pnpm --filter @kamiyo/surfpool run test",
    "lint": "eslint 'packages/**/*.ts' 'services/**/*.ts' --fix",
    "lint:check": "eslint 'packages/**/*.ts' 'services/**/*.ts'",
    "format": "prettier --write 'packages/**/*.ts' 'services/**/*.ts'",
    "format:check": "prettier --check 'packages/**/*.ts' 'services/**/*.ts'",
    "lint:rust": "cargo fmt --all -- --check && cargo clippy --all-targets --all-features -- -D warnings",
    "format:rust": "cargo fmt --all",
    "audit": "pnpm audit && cargo audit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-governance": "^0.3.28",
    "@solana/spl-token": "^0.4.9",
    "@sqds/multisig": "^2.1.4",
    "@types/chai": "^5.2.3",
    "@types/eventsource": "^3.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "chai": "^6.2.1",
    "eventsource": "^4.1.0",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "tsx": "^4.21.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6"
  }
}