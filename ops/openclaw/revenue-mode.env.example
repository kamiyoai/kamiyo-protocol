# Required hard gates
KYO_REQUIRE_RUNTIME_ARTIFACT_CONTRACTS=true
KYO_REQUIRE_KYOSHIN_RUNTIME=true
KYO_REQUIRE_X402_FEED=true
KYO_REQUIRE_RECEIPT_SYNC=true

# x402 generated feed
KYO_X402_GENERATED_FEED_ENABLED=true
KYO_X402_FACILITATOR_BASE_URL=
# Optional overrides:
# KYO_X402_PRICING_URL=
# KYO_X402_PRICING_URLS=
# KYO_X402_ENDPOINTS_JSON=[{"url":"https://api.example.com/api/paid/market","method":"GET","priceUsd":0.005,"expectedPayoutUsd":0.05}]

# Kyoshin DB for receipt sync
KYO_KYOSHIN_DB_PATH=
KYO_RECEIPT_SYNC_MAX_BATCH=1000
KYO_RECEIPT_SOL_PRICE_USD=150
KYO_RECEIPT_ESTIMATED_FEE_SOL=0.00001

# Marketplace live feeds
KYO_AGENT_AI_FEED_URL=
KYO_AGENT_AI_API_KEY=
KYO_AGENT_AI_AUTH_HEADER=Authorization
KYO_AGENT_AI_AUTH_PREFIX=Bearer

KYO_RELEVANCE_FEED_URL=
KYO_RELEVANCE_API_KEY=
KYO_RELEVANCE_AUTH_HEADER=Authorization
KYO_RELEVANCE_AUTH_PREFIX=Bearer

KYO_KORE_FEED_URL=
KYO_KORE_API_KEY=
KYO_KORE_AUTH_HEADER=Authorization
KYO_KORE_AUTH_PREFIX=Bearer

# Optional non-marketplace direct feed
# KYO_DIRECT_API_FEED_URL=
