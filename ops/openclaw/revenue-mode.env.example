# Required hard gates
KYO_REQUIRE_RUNTIME_ARTIFACT_CONTRACTS=true
KYO_REQUIRE_KYOSHIN_RUNTIME=true
KYO_REQUIRE_X402_FEED=true
KYO_REQUIRE_DX_TERMINAL_FEED=false
KYO_REQUIRE_RECEIPT_SYNC=true
KYO_ENABLE_SENTRY_PIPELINE=true
KYO_REQUIRE_SENTRY_PIPELINE=false
KYO_ENABLE_CLAWMART_MONITOR=true
KYO_REQUIRE_CLAWMART_MONITOR=true
KYO_CLAWMART_MONITOR_MAX_TASKS=8
KYO_CLAWMART_MONITOR_TIMEOUT_SECONDS=12
KYO_ENABLE_CLAWMART_STAKING_ROUTE=true
KYO_REQUIRE_CLAWMART_STAKING_ROUTE=true
KYO_ENABLE_REVENUE_GUARD=true
KYO_REQUIRE_REVENUE_GUARD=true
KYO_ENABLE_X402_AGENTCASH=true
KYO_REQUIRE_X402_AGENTCASH=false
KYO_ENABLE_DISTRIBUTION_ENGINE=true
KYO_ENABLE_OPERATOR_LOG=true
KYO_WEEKLY_SPEND_CAP_USD=150
KYO_MIN_JOB_MARGIN_USD=0
KYO_MIN_JOB_SUCCESS_PROB=0.55
KYO_MAX_JOB_COST_USD=50
KYO_X402_ALLOWLIST_PATH=~/.openclaw/workspace/runtime/feeds/x402-allowlist.json
KYO_KAMIYO_STAKING_POOL_URL=https://fundry.collaterize.com/staking/9mEd5iRcdbNUwaCmkPqYggLfg25B2DsTn1w6gNrgvC9d
KYO_CLAWMART_STAKING_SOL_PER_SALE=
KYO_CLAWMART_STAKING_KEYPAIR_PATH=
# KYO_CLAWMART_ORDER_GROSS_USD=
# KYO_CLAWMART_ORDER_COST_USD=0
# KYO_CLAWMART_ORDER_NET_USD=
# KYO_CLAWMART_STAKING_RPC_URL=https://api.mainnet-beta.solana.com
# KYO_CLAWMART_STAKING_ROUTE_CMD=python3 ~/.openclaw/workspace/runtime/scripts/route_to_pool.py
# KYO_CLAWMART_STAKING_DRY_RUN=false
# KYO_CLAWMART_STAKING_RECEIPTS_PATH=~/.openclaw/workspace/runtime/receipts/clawmart-staking-route.jsonl
# KYO_REVENUE_LEDGER_PATH=~/.openclaw/workspace/runtime/receipts/revenue-ledger.jsonl
# KYO_CLAWMART_DASHBOARD_URL=https://www.shopclawmart.com/dashboard

# x402 generated feed
KYO_X402_GENERATED_FEED_ENABLED=true
KYO_X402_FACILITATOR_BASE_URL=
# Optional overrides:
# KYO_X402_PRICING_URL=
# KYO_X402_PRICING_URLS=
# KYO_X402_ENDPOINTS_JSON=[{"url":"https://api.example.com/api/paid/market","method":"GET","priceUsd":0.005,"expectedPayoutUsd":0.05}]

# DX Terminal generated feed
KYO_DX_TERMINAL_ENABLED=true
KYO_DX_TERMINAL_GENERATED_FEED_ENABLED=true
KYO_DX_TERMINAL_API_BASE_URL=https://api.terminal.markets/api/v1
KYO_DX_TERMINAL_MAX_OPPORTUNITIES=24
KYO_DX_TERMINAL_MAX_LEADERBOARD=8
KYO_DX_TERMINAL_MAX_TOKENS=12
KYO_DX_TERMINAL_MIN_TOKEN_VOLUME_USD=5000
KYO_DX_TERMINAL_MIN_TOKEN_HOLDERS=50
KYO_DX_TERMINAL_TIMEFRAME=15m
# Optional:
# KYO_DX_TERMINAL_FEED_URL=
# KYO_DX_TERMINAL_OWNER_ADDRESS=

# Kyoshin DB for receipt sync
KYO_KYOSHIN_DB_PATH=
KYO_RECEIPT_SYNC_MAX_BATCH=1000
KYO_RECEIPT_SOL_PRICE_USD=150
KYO_RECEIPT_ESTIMATED_FEE_SOL=0.00001

# Sentry pipeline
# KYO_SENTRY_WEBHOOK_INBOX_PATH=
# KYO_SENTRY_TRIAGE_OUTPUT_PATH=
# KYO_SENTRY_TRIAGE_STATE_PATH=
KYO_SENTRY_MAX_INCIDENTS=200

# Marketplace live feeds
KYO_AGENT_AI_FEED_URL=
KYO_AGENT_AI_API_KEY=
KYO_AGENT_AI_AUTH_HEADER=Authorization
KYO_AGENT_AI_AUTH_PREFIX=Bearer

KYO_RELEVANCE_FEED_URL=
KYO_RELEVANCE_API_KEY=
KYO_RELEVANCE_AUTH_HEADER=Authorization
KYO_RELEVANCE_AUTH_PREFIX=Bearer

KYO_KORE_FEED_URL=
KYO_KORE_API_KEY=
KYO_KORE_AUTH_HEADER=Authorization
KYO_KORE_AUTH_PREFIX=Bearer

# Optional non-marketplace direct feed
# KYO_DIRECT_API_FEED_URL=

# Optional DigitalOcean agent completion probe (tool-health)
# KYO_DO_AGENT_URL=https://<agent-id>.agents.do-ai.run
# KYO_DO_AGENT_API_KEY=
# KYO_DO_AGENT_CHECK_RETRIEVAL_METHOD=none
# KYO_DO_AGENT_CHECK_PROMPT=Return JSON with key "ok" set to true for health check.
# KYO_DO_AGENT_CHECK_CRITICAL=false
