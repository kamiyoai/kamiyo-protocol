# Core runtime (safe canary bootstrap)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_FALLBACK_URLS=

KAMIYO_MODE=execute
KAMIYO_EXECUTION_STAGE=canary_0
KAMIYO_EXECUTION_HARD_STOP=true
KAMIYO_RUN_ONCE=false
KAMIYO_LOOP_INTERVAL_SECONDS=180

KAMIYO_DB_PATH=output/kyoshin-exec/state.db
KAMIYO_OUTBOX_DIR=output/kyoshin-exec/outbox

# Stage budget caps (canary_0 baseline)
KAMIYO_SOL_DAILY_CAP=0.005
KAMIYO_SOL_PER_TX_CAP=0.001
KAMIYO_MAX_TX_PER_DAY=1

# Swarm intake + planning
KAMIYO_SWARM_ENABLED=true
KAMIYO_SWARM_REGISTRY_PATH=output/kyoshin-exec/swarm.registry.json
KAMIYO_SWARM_MISSIONS_PER_TICK=3
KAMIYO_SWARM_MAX_ACTIVE_AGENTS=4
KAMIYO_SWARM_JOB_INTAKE_ENABLED=true
KAMIYO_SWARM_JOB_FEED_PATH=
KAMIYO_SWARM_JOB_FEED_URLS=
KAMIYO_SWARM_RELEVANCE_FEED_URL=https://api.github.com/search/issues?q=is%3Aissue+is%3Aopen+label%3Abounty&per_page=25
KAMIYO_SWARM_RELEVANCE_API_KEY=
KAMIYO_SWARM_AGENTAI_FEED_URL=
KAMIYO_SWARM_AGENTAI_API_KEY=
KAMIYO_SWARM_KORE_FEED_URL=
KAMIYO_SWARM_KORE_API_KEY=
KAMIYO_SWARM_NEAR_MARKET_FEED_URL=
KAMIYO_SWARM_NEAR_MARKET_API_KEY=
KAMIYO_SWARM_NEAR_MARKET_AUTH_HEADER=authorization
KAMIYO_SWARM_NEAR_MARKET_AGENT_ID=
KAMIYO_SWARM_NEAR_MARKET_BASE_URL=https://market.near.ai
KAMIYO_SWARM_NEAR_MARKET_NEAR_PRICE_USD=4
KAMIYO_SWARM_NEAR_MARKET_MIN_BUDGET_NEAR=0.05
KAMIYO_SWARM_NEAR_MARKET_MAX_BUDGET_NEAR=20
KAMIYO_SWARM_NEAR_MARKET_BID_DISCOUNT_BPS=7000
KAMIYO_SWARM_NEAR_MARKET_MIN_BID_NEAR=0.03
KAMIYO_SWARM_NEAR_MARKET_MAX_BID_NEAR=10
KAMIYO_SWARM_NEAR_MARKET_MAX_EXISTING_BIDS=12
KAMIYO_SWARM_NEAR_MARKET_ETA_SECONDS=3600
KAMIYO_SWARM_NEAR_MARKET_ALLOW_COMPETITION=false
KAMIYO_SWARM_NEAR_MARKET_PROPOSAL_TEMPLATE=Autonomous execution for {title}. Delivery includes deterministic artifacts, clear proof, and deadline compliance.
KAMIYO_SWARM_NEAR_MARKET_SETTLEMENT_ENABLED=true
KAMIYO_SWARM_NEAR_MARKET_SETTLEMENT_INTERVAL_MINUTES=10
KAMIYO_SWARM_NEAR_MARKET_SETTLEMENT_LIMIT=50
KAMIYO_SWARM_NEAR_MARKET_AUTO_SUBMIT_ENABLED=true
KAMIYO_SWARM_NEAR_MARKET_SUBMIT_INTERVAL_MINUTES=5
KAMIYO_SWARM_NEAR_MARKET_SUBMIT_LIMIT=6
KAMIYO_SWARM_NEAR_MARKET_BID_SYNC_ENABLED=true
KAMIYO_SWARM_NEAR_MARKET_BID_SYNC_INTERVAL_MINUTES=5
KAMIYO_SWARM_NEAR_MARKET_BID_SYNC_LIMIT=300
KAMIYO_SWARM_JOB_MAX_OPEN=12
KAMIYO_SWARM_JOB_MIN_REWARD_USD=0
KAMIYO_SWARM_SOL_PRICE_USD=150
KAMIYO_SWARM_JOB_FETCH_TIMEOUT_MS=12000
KAMIYO_SWARM_JOB_EXECUTION_ENABLED=true
KAMIYO_SWARM_JOB_EXECUTIONS_PER_TICK=1
KAMIYO_SWARM_JOB_HTTP_TIMEOUT_MS=20000
KAMIYO_SWARM_JOB_MIN_MARGIN_SOL=0.0005
KAMIYO_SWARM_JOB_ESTIMATED_FEE_SOL=0.00001
KAMIYO_SWARM_JOB_REQUIRE_EXPECTED_REWARD=true
KAMIYO_SWARM_INTAKE_ENABLED=true
KAMIYO_SWARM_INTAKE_MAX_OPEN=16
KAMIYO_SWARM_INTAKE_RETRY_LIMIT=4
KAMIYO_SWARM_INTAKE_RETRY_BASE_SECONDS=120
KAMIYO_SWARM_INTAKE_RETRY_MAX_SECONDS=3600
KAMIYO_SWARM_LEAD_CONVERSION_ENABLED=false
KAMIYO_SWARM_LEAD_CONVERSION_MAX_PER_TICK=4
KAMIYO_SWARM_LEAD_CONVERSION_DEFAULT_PAYOUT_USD=12
KAMIYO_SWARM_LEAD_CONVERSION_REQUIRE_ENDPOINT=true
KAMIYO_SWARM_LEAD_CONVERSION_SIMULATE_ONLY=true
KAMIYO_SWARM_LEAD_CONVERSION_MIN_CONFIDENCE=0.6
KAMIYO_SWARM_LEAD_CONTRACT_VALIDATION=true

# Guard rails
KAMIYO_SWARM_X402_ENABLED=true
KAMIYO_SWARM_X402_MAX_PRICE_USD=2
KAMIYO_SWARM_X402_PREFERRED_NETWORK=solana:mainnet
KAMIYO_SWARM_X402_FACILITATOR_POLICY=prefer-kamiyo
KAMIYO_SWARM_CIRCUIT_BREAKER_ENABLED=true
KAMIYO_SWARM_CIRCUIT_NEG_MARGIN_STREAK=3
KAMIYO_SWARM_CIRCUIT_COOLDOWN_MINUTES=180
KAMIYO_SWARM_CIRCUIT_STATE_KEEP_DAYS=30
KAMIYO_SWARM_ROLLBACK_ENABLED=true
KAMIYO_SWARM_ROLLBACK_EVAL_INTERVAL_HOURS=24
KAMIYO_SWARM_ROLLBACK_WINDOW_DAYS=7
KAMIYO_SWARM_ROLLBACK_NET_SOL_TRIGGER=-0.02
KAMIYO_SWARM_ROLLBACK_RECOVERY_NET_SOL=0
KAMIYO_SWARM_ROLLBACK_MIN_JOBS=5
KAMIYO_SWARM_ROLLBACK_SOURCE_MIN_JOBS=2
KAMIYO_SWARM_ROLLBACK_MAX_DISABLED_SOURCES=2
KAMIYO_SWARM_ROLLBACK_COOLDOWN_HOURS=24
KAMIYO_REVENUE_POLICY_ENABLED=true
KAMIYO_REVENUE_SETTLE_INTERVAL_MINUTES=30
KAMIYO_REVENUE_MIN_NET_SOL=0.001
KAMIYO_REVENUE_ROUTE_BPS=7000
KAMIYO_REVENUE_RESERVE_BPS=2000
KAMIYO_REVENUE_OPERATIONS_BPS=1000
KAMIYO_SELF_IMPROVE_ENABLED=true
KAMIYO_SELF_IMPROVE_INTERVAL_MINUTES=60
KAMIYO_SELF_IMPROVE_WINDOW_HOURS=24
KAMIYO_SELF_IMPROVE_MIN_JOBS=10
KAMIYO_SELF_IMPROVE_FAIL_RATE_UPPER=0.35
KAMIYO_SELF_IMPROVE_FAIL_RATE_LOWER=0.1
KAMIYO_SELF_IMPROVE_MARGIN_STEP_SOL=0.0002
KAMIYO_SELF_IMPROVE_MIN_MARGIN_FLOOR_SOL=0.0002
KAMIYO_SELF_IMPROVE_MAX_EXECUTIONS_PER_TICK=4

# Mutation surfaces stay policy-gated even when hard-stop is removed
KAMIYO_FEE_VAULT=
KAMIYO_AUTO_CLAIM_ENABLED=true
KAMIYO_AUTO_CLAIM_MIN_LAMPORTS=1000000
KAMIYO_STAKING_POOL=
KAMIYO_ALLOWED_STAKING_POOLS=
KAMIYO_REQUIRE_STAKING_POOL_ALLOWLIST=true
KAMIYO_AUTO_STAKE_ENABLED=true
KAMIYO_AUTO_STAKE_MIN_LAMPORTS=50000000
KAMIYO_AUTO_STAKE_RESERVE_LAMPORTS=200000000
KAMIYO_AUTO_STAKE_AVAILABLE_BPS=1500
KAMIYO_AUTO_STAKE_MAX_LAMPORTS_PER_TX=25000000
KAMIYO_AUTO_STAKE_MAX_FEEDS_PER_DAY=24
KAMIYO_KYOSHIN_STAKING_POOL=
KAMIYO_KYOSHIN_CLAIMER_KEYPAIR_PATH=
KAMIYO_KYOSHIN_CLAIMER_PRIVATE_KEY=
KAMIYO_KYOSHIN_AUTO_CLAIM_ENABLED=true
KAMIYO_KYOSHIN_AUTO_CLAIM_MIN_LAMPORTS=0
KAMIYO_KYOSHIN_AUTO_CLAIM_MAX_PERIODS_PER_RUN=8
KAMIYO_FUNDRY_API_BASE_URL=https://fundry.collaterize.com

# Control plane: keep local-only and token gated
KYOSHIN_HTTP_ENABLED=true
KYOSHIN_HTTP_HOST=127.0.0.1
KYOSHIN_HTTP_PORT=4020
KYOSHIN_HTTP_TOKEN=replace-with-random-token
