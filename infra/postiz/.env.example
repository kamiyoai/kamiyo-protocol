# Postiz self-hosted — copy to .env and fill before `docker compose up -d`.

# URLs — change if fronting with a reverse proxy / custom domain.
POSTIZ_MAIN_URL=http://localhost:5000
POSTIZ_FRONTEND_URL=http://localhost:5000
POSTIZ_BACKEND_URL=http://localhost:5000/api
POSTIZ_PORT=5000

# Required secrets. JWT_SECRET: generate with `openssl rand -hex 32`.
POSTIZ_JWT_SECRET=
POSTIZ_DB_PASSWORD=

# Open registration off by default for an agent-only deployment.
POSTIZ_DISABLE_REGISTRATION=true

# X (Twitter) OAuth 1.0a credentials — leave blank to configure via UI later.
POSTIZ_X_API_KEY=
POSTIZ_X_API_SECRET=
