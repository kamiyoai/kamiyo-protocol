{
  "expo": {
    "name": "KAMIYO",
    "slug": "kamiyo",
    "version": "0.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kamiyo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.kamiyo.keiro"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "ai.kamiyo.keiro",
      "versionCode": 2,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "unstable_transformProfile": "default"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "74b276b1-3abd-4e06-b051-5a0ce26f72c9"
      }
    },
    "owner": "kamiyo"
  }
}
