{
  "name": "@kamiyo/keiro",
  "version": "0.0.1",
  "private": true,
  "description": "Mobile client for the Kamiyo Protocol — manage AI agents with stake-backed identities, escrow payments, and verifiable reputation on Solana.",
  "license": "MIT",
  "author": "KAMIYO <dev@kamiyo.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamiyo-ai/kamiyo-protocol.git",
    "directory": "apps/keiro"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@solana-mobile/mobile-wallet-adapter-protocol": "^2.1.3",
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.1.3",
    "@solana/web3.js": "1.95.8",
    "bs58": "^6.0.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.0",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.1.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "typescript": "~5.9.2"
  }
}
