{
  "name": "kamiyo-hyperliquid-subgraph",
  "version": "1.0.0",
  "description": "Subgraph for KAMIYO Hyperliquid contracts",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamiyo-ai/kamiyo-protocol"
  },
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "create-local": "graph create --node http://localhost:8020/ kamiyo/hyperliquid",
    "remove-local": "graph remove --node http://localhost:8020/ kamiyo/hyperliquid",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 kamiyo/hyperliquid",
    "deploy-studio": "graph deploy --studio kamiyo-hyperliquid",
    "test": "graph test"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "0.71.0",
    "@graphprotocol/graph-ts": "0.32.0"
  },
  "devDependencies": {
    "matchstick-as": "0.6.0"
  }
}
